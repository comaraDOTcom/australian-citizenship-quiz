# MotherDuck - https://app.motherduck.com/settings/integrations
MOTHERDUCK_TOKEN=your_motherduck_token_here

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Omni Embed - Settings > Embed > Admin in your Omni instance
OMNI_EMBED_SECRET=your_omni_embed_secret_here
OMNI_ORG_SLUG=your-org-name
# The dashboard ID to embed for analytics (create in Omni connected to MotherDuck)
OMNI_DASHBOARD_ID=your_dashboard_id_here

# Email reminders via Resend - https://resend.com
RESEND_API_KEY=your_resend_api_key_here
REMINDER_FROM_EMAIL=quiz@yourdomain.com

# App URL (for emails and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
